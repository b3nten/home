{
	"tasks": {
		"dev": "deno run -A ./internal/cli.ts",
		"build": "deno run -A ./internal/cli.ts build"
	},
	"compilerOptions": {
		"lib": ["deno.ns", "deno.window", "dom"],
		"jsxImportSource": "https://esm.sh/preact",
		"jsxFactory": "h",
		"jsx":"react-jsx",
		"jsxFragmentFactory": "Fragment"
	},
	"lock": false
}